<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Note.FirstPage"
             Title="Вход">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="Note" 
                   FontSize="36" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   Margin="0,0,0,30"/>

            <Frame CornerRadius="10" Padding="15" BackgroundColor="White">
                <Entry x:Name="EmailEntry" 
                       Placeholder="Email" 
                       Keyboard="Email"
                       FontSize="16"
                       TextColor="Black"/>
            </Frame>

            <Frame CornerRadius="10" Padding="15" BackgroundColor="White">
                <Entry x:Name="PasswordEntry" 
                       Placeholder="Пароль" 
                       IsPassword="True"
                       FontSize="16"
                       TextColor="Black"/>
            </Frame>

            <Label x:Name="ErrorLabel" 
                   TextColor="Red" 
                   FontSize="14"
                   IsVisible="False"/>

            <Button x:Name="LoginButton"
                    Text="Войти"
                    Clicked="Login_Clicked"
                    BackgroundColor="#007ACC"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontSize="18"/>

            <ActivityIndicator x:Name="LoadingIndicator" 
                              IsRunning="False" 
                              IsVisible="False"
                              Color="#007ACC"
                              HeightRequest="40"/>

            <Label Text="или" 
                   HorizontalOptions="Center" 
                   TextColor="#666"
                   Margin="0,20,0,0"/>

            <Button Text="Создать аккаунт"
                    Clicked="Register_Clicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontSize="16"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>