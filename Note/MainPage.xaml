<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Note.MainPage"
             Title="Главная">

    <Grid ColumnDefinitions="400,700" ColumnSpacing="15" 
          Padding="20,10" VerticalOptions="Fill"
          BackgroundColor="#E8E8E8">

        <!-- Левая панель -->
        <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *" RowSpacing="15" Padding="0,0,0,15">

            <Border Grid.Row="0" Stroke="#D3D3D3" BackgroundColor="#D3D3D3" StrokeShape="RoundRectangle 10" Padding="15,10">
                <HorizontalStackLayout Spacing="10">
                    <Label x:Name="UserEmailLabel" Text="user@email.com" TextColor="Black" FontSize="14" VerticalOptions="Center" HorizontalOptions="StartAndExpand"/>
                    <Button Text="Выйти" Clicked="Logout_Clicked" BackgroundColor="#F44336" TextColor="White" CornerRadius="8" Padding="15,5" FontSize="12" HorizontalOptions="End"/>
                </HorizontalStackLayout>
            </Border>

            <Border Grid.Row="1" Stroke="#D3D3D3" BackgroundColor="#D3D3D3" StrokeShape="RoundRectangle 10" Padding="10,5">
                <Entry x:Name="SearchEntry" Placeholder="Поиск" BackgroundColor="Transparent" TextColor="Black" TextChanged="OnSearchTextChanged" PlaceholderColor="Black"/>
            </Border>

            <Border Grid.Row="2" Stroke="#D3D3D3" BackgroundColor="#D3D3D3" StrokeShape="RoundRectangle 10" Padding="0">
                <ScrollView>
                    <VerticalStackLayout x:Name="NotesStackLayout" Spacing="10" Padding="10"/>
                </ScrollView>
            </Border>
        </Grid>

        <!-- Правая панель -->
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="15" BackgroundColor="Gray" Padding="10">

            <Border Grid.Row="0" Stroke="#696969" BackgroundColor="#696969" StrokeShape="RoundRectangle 20" Padding="20,10" HorizontalOptions="Start" WidthRequest="300">
                <Entry x:Name="TitleEntry" Placeholder="Название..." BackgroundColor="Transparent" TextColor="White" PlaceholderColor="#B0B0B0"/>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="15">
                <Border Grid.Column="0" Stroke="#C0C0C0" BackgroundColor="#C0C0C0" StrokeShape="RoundRectangle 15" Padding="15">
                    <Editor x:Name="TextEditor" Placeholder="Текст..." BackgroundColor="Transparent" TextColor="Black" PlaceholderColor="#4A4A4A" AutoSize="TextChanges" VerticalOptions="FillAndExpand"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Start">

                    <Border BackgroundColor="#D3D3D3" Stroke="#696969" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,5">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Дата напоминания:" FontSize="12" TextColor="Black"/>
                            <DatePicker x:Name="ReminderDatePicker" Format="dd.MM.yyyy" IsEnabled="False" HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#D3D3D3" Stroke="#696969" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,5">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Время напоминания:" FontSize="12" TextColor="Black"/>
                            <TimePicker x:Name="ReminderTimePicker" IsEnabled="False" HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="BtnNote" Text="Заметка" Clicked="OnNoteTypeClicked" CommandParameter="Заметка" BackgroundColor="#A8D8EA" TextColor="Black" CornerRadius="10" HeightRequest="40"/>
                    <Button x:Name="BtnReminder" Text="Напоминание" Clicked="OnNoteTypeClicked" CommandParameter="Напоминание" BackgroundColor="Transparent" TextColor="Black" CornerRadius="10" HeightRequest="40"/>

                    <Button Text="Сохранить" Clicked="OnSaveClicked" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="10" HeightRequest="45" Margin="0,10,0,0"/>
                    <Button Text="Отмена" Clicked="OnCancelClicked" BackgroundColor="#9E9E9E" TextColor="White" CornerRadius="10" HeightRequest="45"/>

                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>