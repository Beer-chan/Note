<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Note.MainPage">

    <Grid ColumnDefinitions="400,700" ColumnSpacing="15" 
          Padding="20,10" VerticalOptions="Fill"
          BackgroundColor="#E8E8E8">

        <!-- Левая панель -->
        <Grid Grid.Column="0" RowDefinitions="Auto, *" RowSpacing="15" Padding="0,0,0,15">

            <!--ка -->
            <Border Grid.Row="0"
                    Stroke="#D3D3D3"
                    BackgroundColor="#D3D3D3"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,5">
                <Entry x:Name="SearchEntry"
                       Placeholder="Поиск" 
                       BackgroundColor="Transparent"
                       TextColor="Black"
                       TextChanged="OnSearchTextChanged"
                       PlaceholderColor="Black"/>
            </Border>

            <!-- Список заметок -->
            <Border Grid.Row="1"
                    Stroke="#D3D3D3"
                    BackgroundColor="#D3D3D3"
                    StrokeShape="RoundRectangle 10"
                    Padding="0">
                <ScrollView>
                    <VerticalStackLayout x:Name="NotesStackLayout"
                                         Spacing="10"
                                         Padding="10"/>
                </ScrollView>
            </Border>
        </Grid>

        <!-- Основная область -->
        <Grid Grid.Column="1" 
              RowDefinitions="Auto,Auto,*" 
              RowSpacing="15"
              BackgroundColor="Gray"
              Padding="10"
              Margin="0,0,0,0">

            <!-- Заголовок -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="0,0,0,10">

                <!-- Поле названия -->
                <Border Grid.Column="0"
                        Stroke="#696969"
                        BackgroundColor="#696969"
                        StrokeShape="RoundRectangle 20"
                        Padding="20,10"
                        HorizontalOptions="Start"
                        WidthRequest="300">
                    <Entry x:Name="TitleEntry"
                           Placeholder="Название..." 
                           BackgroundColor="Transparent"
                           TextColor="White"
                           PlaceholderColor="#B0B0B0"/>
                </Border>
            </Grid>

            <!-- Текстовая область -->
            <Grid Grid.Row="1" 
                  ColumnDefinitions="*,Auto" 
                  ColumnSpacing="15"
                  VerticalOptions="FillAndExpand">

                <!-- Текстовое поле -->
                <Border Grid.Column="0"
                        Stroke="#C0C0C0"
                        BackgroundColor="#C0C0C0"
                        StrokeShape="RoundRectangle 15"
                        Padding="15">
                    <Editor x:Name="TextEditor"
                            Placeholder="Текст..." 
                            BackgroundColor="Transparent"
                            TextColor="Black"
                            PlaceholderColor="#4A4A4A"
                            AutoSize="TextChanges"
                            VerticalOptions="FillAndExpand"/>
                </Border>

                <!-- Правая панель с кнопками -->
                <VerticalStackLayout Grid.Column="1" 
                                     Spacing="8"
                                     VerticalOptions="Start">

                    <!-- Кнопка Заметка -->
                    <Border BackgroundColor="#D3D3D3"
                            Stroke="#696969"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 15"
                            Padding="15,10"
                            HorizontalOptions="Fill"
                            Margin="0,0,0,0">
                        <Button x:Name="BtnNote"
                                Text="Заметка"
                                BackgroundColor="Transparent"
                                TextColor="Black"
                                FontSize="14"
                                Clicked="OnNoteTypeClicked"
                                CommandParameter="Заметка"/>
                    </Border>

                    <!-- Кнопка Напоминание -->
                    <Border BackgroundColor="#E8E8E8"
                            Stroke="#696969"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 15"
                            Padding="15,10"
                            HorizontalOptions="Fill"
                            Margin="0,0,0,0">
                        <Button x:Name="BtnReminder"
                                Text="Напоминание"
                                BackgroundColor="Transparent"
                                TextColor="Black"
                                FontSize="14"
                                Clicked="OnNoteTypeClicked"
                                CommandParameter="Напоминание"/>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
